if __name__ == '__main__':

    if len(sys.argv) > 0:
        print('args:', sys.argv[1:])
        input_id_list = sys.argv[1:]
        download_list_of_ids(input_id_list)


    else: # zero arguments, enter REPL
        while True:
            line = input('Space separated list of ids (or "exit"): ')

            if line == 'exit':
                exit()
            else:
                input_id_list = line.split(' ')
                download_list_of_ids(input_id_list)

